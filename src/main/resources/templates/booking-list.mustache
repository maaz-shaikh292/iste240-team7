<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Booking List</title>
</head>
<body>
    <h1>All Car Bookings</h1>
    <table border="1">
        <thead>
            <tr>
                <th>Start Date</th>
                <th>End Date</th>
                <th>Total Cost</th>
                <th>Confirmed</th>
                <th>Customer Name</th> </tr>
        </thead>
        <tbody>
            {{#bookings}}
            <tr>
                <td>{{startDate}}</td>
                <td>{{endDate}}</td>
                <td>{{totalCost}}</td>
                <td>{{confirmed}}</td>
                <td>{{customer.username}}</td>
            </tr>
            {{/bookings}}
        </tbody>
    </table>
    <br>
    <a href="/">Back to Home</a>
</body>
</html>