<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Create Booking</title>
</head>
<body>
    <h1>Create a New Booking</h1>
    <form action="/bookings/add" method="post">
        <label>Start Date:</label>
        <input type="text" name="startDate" placeholder="YYYY-MM-DD" required><br><br>

        <label>End Date:</label>
        <input type="text" name="endDate" placeholder="YYYY-MM-DD" required><br><br>

        <label>Total Cost:</label>
        <input type="number" step="0.01" name="totalCost" required><br><br>

        <label>Assign to Customer:</label>
        <select name="customerUsername">
            {{#customers}} <option value="{{username}}">{{username}}</option>
            {{/customers}}
        </select><br><br>

        <button type="submit">Confirm Booking</button>
    </form>
    <br>
    <a href="/">Back to Home</a>
</body>
</html>