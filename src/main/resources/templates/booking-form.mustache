<!DOCTYPE html>
<html lang="en">
<head>
    <link rel="stylesheet" href="/webjars/semantic-ui-css/2.4.0/semantic.min.css">
    <script src="/webjars/semantic-ui-css/2.4.0/semantic.min.js"></script>
    <meta charset="UTF-8">
    <title>Create Booking</title>
</head>
<body>
    <h1>Create a New Booking</h1>
    <form action="/bookings/add" method="post" class="ui form">
        <div class="field">
            <label>Start Date:</label>
            <input type="text" name="startDate" placeholder="YYYY-MM-DD" required>
        </div>
        <div class="field">
            <label>End Date:</label>
            <input type="text" name="endDate" placeholder="YYYY-MM-DD" required>
        </div>

        <div class="field">
            <label>Total Cost:</label>
            <input type="number" step="0.01" name="totalCost" required>
        </div>


        <div class="field">
            <label>Assign to Customer:</label>
            <select class="ui dropdown" name="customerUsername">
                {{#customers}}
                    <option value="{{username}}">{{username}}</option>
                {{/customers}}
            </select>
        </div>



        <button class="ui button" type="submit">Submit</button>
    </form>
    <br>
    <a href="/">Back to Home</a>


</body>
</html>



