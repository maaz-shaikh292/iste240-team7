<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Customer List</title>
</head>
<body>
    <h1>All Registered Customers</h1>
    <table border="1">
        <thead>
            <tr>
                <th>Username</th>
                <th>Email</th>
                <th>License Number</th>
            </tr>
        </thead>
        <tbody>
            {{#customers}} <tr>
                <td>{{username}}</td> <td>{{email}}</td>
                <td>{{licenseNumber}}</td>
            </tr>
            {{/customers}} </tbody>
    </table>
    <br>
    <a href="/">Back to Home</a> </body>
</html>